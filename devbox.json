{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": ["go@1.24", "nodejs@22"],
  "shell": {
    "init_hook": [
      "git config core.hooksPath .githooks"
    ],
    "scripts": {
      "test": ["go test ./..."],
      "fmt": ["gofmt -w $(find . -name '*.go' -not -path './vendor/*')"],
      "vet": ["go vet ./..."],
      "build": ["make build"]
    }
  }
}
