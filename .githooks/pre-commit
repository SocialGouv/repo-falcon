#!/usr/bin/env bash
set -euo pipefail

# Pre-commit hook: Go formatting and static analysis
# Runs on staged .go files only for speed.

# Collect staged Go files (excluding deleted files)
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=d -- '*.go' | grep -v '^vendor/' || true)

if [ -z "$STAGED_GO_FILES" ]; then
  exit 0
fi

PASS=true

# --- gofmt ---
UNFORMATTED=$(echo "$STAGED_GO_FILES" | xargs gofmt -l 2>/dev/null || true)
if [ -n "$UNFORMATTED" ]; then
  echo "❌ gofmt: the following files need formatting:"
  echo "$UNFORMATTED"
  echo ""
  echo "Run: make fmt"
  PASS=false
fi

# --- go vet ---
if ! go vet ./... 2>&1; then
  echo "❌ go vet: issues found"
  PASS=false
fi

if ! $PASS; then
  echo ""
  echo "Pre-commit checks failed. Fix the issues above and try again."
  exit 1
fi

echo "✅ Pre-commit checks passed"
