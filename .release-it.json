{
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}"
  },
  "npm": {
    "publish": false
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "conventionalcommits",
      "infile": false
    }
  },
  "hooks": {
    "after:bump": "make build && npm version ${version} --no-git-tag-version --prefix npm && git add npm/package.json"
  }
}
